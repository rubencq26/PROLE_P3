/**
 * Aplicaciï¿½n que muestra el factorial de un nï¿½mero
 */
library Main {

  /**
   * Punto de entrada de la aplicaciï¿½n
   */
  public void Main() {
    int a=5;
    int f=factorial(a);
    Console.print(a);
    Console.print('!');
    Console.print('=');
    Console.print(' ');
    Console.print(f);
  }

  /**
   * Calcula el factorial de un nï¿½mero
   */
  private int factorial(int a) {
    if(a == 1) return 1;
    int c = factorial(a-1);
    return a*c;
  }
}
